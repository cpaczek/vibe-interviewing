{
  "name": "@vibe-interviewing/core",
  "version": "0.1.0",
  "description": "Core library for vibe-interviewing — scenario engine, Docker runtime, AI tool launchers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dockerode": "^4.0.4",
    "simple-git": "^3.27.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/dockerode": "^3.3.34",
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cpaczek/vibe-interviewing.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/cpaczek/vibe-interviewing#readme",
  "bugs": {
    "url": "https://github.com/cpaczek/vibe-interviewing/issues"
