{
  "name": "vibe-interviewing",
  "version": "0.1.1",
  "description": "AI-era technical interviews — evaluate how engineers work with AI, not what they memorize",
  "type": "module",
  "bin": {
    "vibe-interviewing": "./dist/vibe-interviewing.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "commands/",
    "scripts/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "postinstall": "node ./scripts/postinstall.mjs"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.0",
    "@vibe-interviewing/core": "workspace:*",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.1.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "interview",
    "ai",
    "claude",
    "cli",
    "coding-interview",
    "technical-interview"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cpaczek/vibe-interviewing.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/cpaczek/vibe-interviewing#readme",
  "bugs": {
    "url": "https://github.com/cpaczek/vibe-interviewing/issues"
  }
}
